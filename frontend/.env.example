# Browser-side: relative URL so requests go through Next.js → backend.
# Keep default unless you really want to hit the backend cross-origin.
NEXT_PUBLIC_API_BASE=/api/v1

# Browser-side: where Socket.IO connects for real-time events.
# Next.js dev server can't proxy WebSocket upgrade, so in dev we bypass the
# proxy and talk to the backend directly. In prod behind a WS-aware reverse
# proxy (nginx, caddy, cloudflared tunnel), leave this EMPTY for same-origin.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Server-side only: where the Next.js server proxies /api calls.
# In Docker Compose this is the internal service name (e.g. http://api:4000).
BACKEND_URL=http://localhost:4000
