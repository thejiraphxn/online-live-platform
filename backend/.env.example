DATABASE_URL=postgresql://olp:olp@localhost:5432/olp
REDIS_URL=redis://localhost:6379
PORT=4000
# CORS_ORIGIN accepts:
#   - a single origin:        http://localhost:3000
#   - a comma-separated list: http://localhost:3000,https://staging.example.com
#   - "*" (any origin, reflected — works with credentials unlike a literal "*")
#
# With the Next.js proxy (same-origin) this rarely matters, but it's used
# when the browser hits the API directly in dev.
CORS_ORIGIN=http://localhost:3000

JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d

# Cookie options — behind a reverse proxy / Next.js rewrite on HTTPS, set
# COOKIE_SECURE=true. Use COOKIE_SAMESITE=none only for cross-site scenarios
# (must pair with COOKIE_SECURE=true).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

S3_ENDPOINT=http://localhost:9000
PUBLIC_S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=olp-recordings
S3_FORCE_PATH_STYLE=true

# FFmpeg transcode tuning — speed vs quality vs file size.
# Preset: ultrafast (fastest, larger) | veryfast | faster | fast | medium (default)
# CRF: 18 (near lossless, huge) → 23 (balanced) → 28 (smaller, OK) → 35 (tiny, blocky)
FFMPEG_PRESET=ultrafast
FFMPEG_CRF=28

# === Whisper (audio → transcript) ===
# Any Whisper-compatible endpoint works. Leave WHISPER_API_KEY blank to skip
# transcription entirely (recording still processes, just no transcript).
#
# Groq (recommended — fastest + free tier 28,800 sec/day):
#   WHISPER_API_KEY=gsk_...                                 # from console.groq.com
#   WHISPER_API_BASE_URL=https://api.groq.com/openai/v1
#   WHISPER_MODEL=whisper-large-v3
#
# Self-hosted faster-whisper-server (docker profile "whisper"):
#   WHISPER_API_KEY=any-non-empty-string
#   WHISPER_API_BASE_URL=http://localhost:8000/v1           # http://whisper:8000/v1 inside docker
#   WHISPER_MODEL=Systran/faster-whisper-small
#   WHISPER_MAX_UPLOAD_MB=500                               # lift cap for local servers
WHISPER_API_KEY=
WHISPER_API_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=whisper-large-v3

# === LLM (transcript → summary + auto-chapters) ===
# Speaks /v1/chat/completions — works with virtually any provider.
#
#   Groq           LLM_API_URL=https://api.groq.com/openai/v1    MODEL=llama-3.3-70b-versatile
#   Ollama Cloud   LLM_API_URL=https://ollama.com/v1             MODEL=gemma3:27b-cloud
#   Ollama local   LLM_API_URL=http://localhost:11434/v1         MODEL=gemma3:4b
#   Typhoon (TH)   LLM_API_URL=https://api.opentyphoon.ai/v1     MODEL=typhoon-v2-70b-instruct
#
# Leave LLM_API_URL blank → client falls back to WHISPER_API_BASE_URL +
# WHISPER_API_KEY so one provider (e.g. Groq) covers both.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
